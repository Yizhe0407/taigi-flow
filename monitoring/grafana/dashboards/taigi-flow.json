{
  "title": "Taigi-Flow",
  "uid": "taigi-flow",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "taigi_sessions_active",
          "legendFormat": "active"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "Turns / min",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "rate(taigi_turns_total[1m]) * 60",
          "legendFormat": "turns/min"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "Conversion Latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(taigi_conversion_duration_seconds_bucket[2m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(taigi_conversion_duration_seconds_bucket[2m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "STT Latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(taigi_stt_duration_seconds_bucket[2m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(taigi_stt_duration_seconds_bucket[2m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 5,
      "title": "TTS Latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(taigi_tts_duration_seconds_bucket[2m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(taigi_tts_duration_seconds_bucket[2m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 6,
      "title": "LLM Tokens / min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(taigi_llm_tokens_total{type=\"input\"}[1m]) * 60",
          "legendFormat": "input tokens/min"
        },
        {
          "expr": "rate(taigi_llm_tokens_total{type=\"output\"}[1m]) * 60",
          "legendFormat": "output tokens/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "Total Turns",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 5 },
      "targets": [
        {
          "expr": "increase(taigi_turns_total[5m])",
          "legendFormat": "turns (5m window)"
        }
      ]
    }
  ]
}
