# Database
DATABASE_URL=postgresql://admin:CHANGEME@localhost:5432/agent_system
POSTGRES_PASSWORD=

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM
# Preferred keys (worker + CLI)
LLM_API_KEY=ollama
LLM_BASE_URL=http://100.107.45.116:11434/v1
LLM_MODEL=frob/qwen3.5-instruct:9b
LLM_FIRST_TOKEN_TIMEOUT=15.0
AGENT_PROFILE_NAME=公車站長

# Backward-compatible keys (worker accepts both)
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://100.107.45.116:11434/v1

# ASR
# Select backend: qwen3 or breeze26
ASR_BACKEND=qwen3
ASR_URL=http://100.107.45.116:8001/v1/audio/transcriptions
QWEN3_ASR_MODEL=qwen3-asr-0.6b
BREEZE_ASR_MODEL=breeze-asr-26
BREEZE_ASR_URL=http://100.107.45.116:8001/v1/audio/transcriptions

# TTS — Piper HTTP backend (Docker local CPU)
# Piper runs in docker-compose as the 'piper' service.
# Remove PIPER_TTS_API_URL to fall back to in-process piper-tts package.
PIPER_MODEL_PATH=models/taigi.onnx
PIPER_MODEL_FILE=taigi.onnx
PIPER_SPEAKER_ID=
PIPER_TTS_API_URL=http://localhost:5050
PIPER_TTS_VOICE=taigi
PIPER_TTS_SPEED=1.1
PIPER_TTS_NOISE_SCALE=0.8
PIPER_TTS_NOISE_SCALE_W=0.8

# TDX (交通部 API)
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=
