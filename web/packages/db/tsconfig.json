{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "rootDir": ".",
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["prisma", "src"],
  "exclude": ["node_modules", "dist"]
}
