generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ Agent 人格管理 ============
model AgentProfile {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  systemPrompt String   @db.Text
  voiceConfig  Json
  ragConfig    Json?
  tools        Json
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions Session[]
}

// ============ 單一對話 Session ============
model Session {
  id              String       @id @default(uuid())
  agentProfileId  String
  agentProfile    AgentProfile @relation(fields: [agentProfileId], references: [id])
  livekitRoom     String
  startedAt       DateTime     @default(now())
  endedAt         DateTime?
  currentLocation Json? // { lat: number, lng: number, label: string }

  logs InteractionLog[]

  @@index([livekitRoom])
}

// ============ 對話日誌 ============
model InteractionLog {
  id        String  @id @default(uuid())
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
  turnIndex Int

  userAsrText String  @db.Text
  llmRawText  String  @db.Text
  hanloText   String? @db.Text
  taibunText  String  @db.Text

  latencyAsrEnd      Int?
  latencyLlmFirstTok Int?
  latencyFirstAudio  Int?
  latencyTotal       Int?

  ragHitCount  Int?
  ragTopSim    Float?
  latencyRagMs Int?

  wasBargedIn Boolean @default(false)
  errorFlag   String?

  createdAt DateTime @default(now())

  @@index([sessionId, turnIndex])
}

// ============ 發音字典 ============
model PronunciationEntry {
  id          String   @id @default(uuid())
  profileId   String?
  term        String
  replacement String
  priority    Int      @default(0)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Uniqueness enforced by two partial indexes in migration (NULL-safe).
  // Do NOT add @@unique here — Prisma would generate a non-partial index
  // that allows duplicate global (profileId=NULL) terms.
  @@index([term])
}

// ============ RAG 向量儲存 ============
model KnowledgeChunk {
  id           String                       @id @default(uuid())
  collectionId String
  content      String                       @db.Text
  metadata     Json
  embedding    Unsupported("vector(1024)")?

  createdAt DateTime @default(now())

  @@index([collectionId])
}

// ============ Ingest 佇列 ============
model IngestJob {
  id           String   @id @default(uuid())
  collectionId String
  fileName     String
  filePath     String
  status       String   @default("pending")
  error        String?
  chunkCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
  @@index([collectionId])
}

// ============ 公車路線 ============
model BusOperator {
  id     String @id
  code   String
  nameZh String
  nameEn String

  routes BusRoute[]
}

model BusRoute {
  uid        String  @id
  routeId    String
  nameZh     String
  nameEn     String
  headsign   String?
  direction  Int
  city       String
  operatorId String

  operator  BusOperator   @relation(fields: [operatorId], references: [id])
  stops     RouteStop[]
  schedules BusSchedule[]

  @@index([city])
  @@index([nameZh])
}

model BusStop {
  uid     String  @id
  stopId  String
  nameZh  String
  nameEn  String
  lat     Float
  lng     Float
  address String?
  city    String

  routeStops RouteStop[]

  @@index([city])
  @@index([nameZh])
}

model RouteStop {
  routeUid String
  stopUid  String
  sequence Int
  boarding Boolean @default(true)

  route BusRoute @relation(fields: [routeUid], references: [uid])
  stop  BusStop  @relation(fields: [stopUid], references: [uid])

  @@id([routeUid, stopUid, sequence])
  @@index([routeUid, sequence])
  @@index([stopUid])
}

model BusSchedule {
  id          String  @id @default(uuid())
  routeUid    String
  tripId      String
  serviceDays Int
  isLowFloor  Boolean @default(false)
  stopTimes   Json

  route BusRoute @relation(fields: [routeUid], references: [uid])

  @@index([routeUid, serviceDays])
}
